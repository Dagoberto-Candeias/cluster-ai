# =============================================================================
# Cluster AI - Arquivo de Configuração
# =============================================================================
# Este arquivo contém todas as configurações do Cluster AI.
# Copie este arquivo para cluster.conf e edite os valores conforme necessário.

# =============================================================================
# CONFIGURAÇÕES GERAIS
# =============================================================================

# Nome do cluster
CLUSTER_NAME="cluster-ai"

# Modo de operação (development/production)
CLUSTER_MODE="development"

# Nível de log (DEBUG/INFO/WARN/ERROR)
LOG_LEVEL="INFO"

# Diretório raiz do projeto (gerado automaticamente)
PROJECT_ROOT=""

# Arquivo de configuração (gerado automaticamente)
CONFIG_FILE=""

# =============================================================================
# CONFIGURAÇÕES DE DIRETÓRIOS
# =============================================================================

# Diretório de logs
LOG_DIR="logs"

# Diretório de backups
BACKUP_DIR="backups"

# Diretório de dados
DATA_DIR="data"

# Diretório de modelos
MODELS_DIR="models"

# Diretório temporário
TEMP_DIR="temp"

# =============================================================================
# CONFIGURAÇÕES DE PYTHON
# =============================================================================

# Caminho para o ambiente virtual
PYTHON_VENV="${PROJECT_ROOT}/.venv"

# Versão Python mínima requerida
PYTHON_MIN_VERSION="3.8"

# =============================================================================
# CONFIGURAÇÕES DE DASK
# =============================================================================

# Porta do scheduler Dask
DASK_SCHEDULER_PORT="8786"

# Porta do dashboard Dask
DASK_DASHBOARD_PORT="8787"

# Endereço do scheduler (localhost para desenvolvimento)
DASK_SCHEDULER_ADDRESS="tcp://localhost:8786"

# Número de workers Dask (0 = automático)
DASK_NUM_WORKERS="0"

# Memória por worker (GB)
DASK_WORKER_MEMORY="2GB"

# Número de threads por worker
DASK_WORKER_THREADS="2"

# =============================================================================
# CONFIGURAÇÕES DE OLLAMA
# =============================================================================

# Porta do servidor Ollama
OLLAMA_PORT="11434"

# Host do servidor Ollama
OLLAMA_HOST="localhost"

# Modelo padrão do Ollama
OLLAMA_DEFAULT_MODEL="llama2"

# Timeout para requests do Ollama (segundos)
OLLAMA_TIMEOUT="30"

# =============================================================================
# CONFIGURAÇÕES DE OPENWEBUI
# =============================================================================

# Porta do OpenWebUI
OPENWEBUI_PORT="3000"

# Host do OpenWebUI
OPENWEBUI_HOST="localhost"

# URL base do OpenWebUI
OPENWEBUI_BASE_URL="http://localhost:3000"

# =============================================================================
# CONFIGURAÇÕES DE NGINX
# =============================================================================

# Porta HTTP do Nginx
NGINX_HTTP_PORT="80"

# Porta HTTPS do Nginx
NGINX_HTTPS_PORT="443"

# Arquivo de configuração do Nginx
NGINX_CONFIG_FILE="configs/nginx/cluster-ai.conf"

# =============================================================================
# CONFIGURAÇÕES DE DOCKER
# =============================================================================

# Rede Docker do cluster
DOCKER_NETWORK="cluster-ai-network"

# Nome do container do scheduler
DOCKER_SCHEDULER_CONTAINER="cluster-ai-scheduler"

# Nome do container do dashboard
DOCKER_DASHBOARD_CONTAINER="cluster-ai-dashboard"

# Nome do container do Ollama
DOCKER_OLLAMA_CONTAINER="cluster-ai-ollama"

# Nome do container do OpenWebUI
DOCKER_OPENWEBUI_CONTAINER="cluster-ai-openwebui"

# =============================================================================
# CONFIGURAÇÕES DE SEGURANÇA
# =============================================================================

# Habilitar SSL/TLS
ENABLE_SSL="false"

# Caminho para certificado SSL
SSL_CERT_PATH="configs/tls/cert.pem"

# Caminho para chave privada SSL
SSL_KEY_PATH="configs/tls/key.pem"

# Habilitar autenticação
ENABLE_AUTH="false"

# Usuário para autenticação básica
AUTH_USER="admin"

# Senha para autenticação básica (use hash)
AUTH_PASSWORD_HASH=""

# Habilitar firewall
ENABLE_FIREWALL="true"

# Portas abertas no firewall
FIREWALL_PORTS="22,80,443,3000,8786,8787,11434"

# =============================================================================
# CONFIGURAÇÕES DE MONITORAMENTO
# =============================================================================

# Habilitar monitoramento
ENABLE_MONITORING="true"

# Porta do Prometheus
PROMETHEUS_PORT="9090"

# Porta do Grafana
GRAFANA_PORT="3001"

# Intervalo de coleta de métricas (segundos)
METRICS_INTERVAL="30"

# Retenção de logs (dias)
LOG_RETENTION_DAYS="7"

# =============================================================================
# CONFIGURAÇÕES DE BACKUP
# =============================================================================

# Habilitar backups automáticos
ENABLE_AUTO_BACKUP="true"

# Intervalo de backup (horas)
BACKUP_INTERVAL_HOURS="24"

# Número máximo de backups a manter
MAX_BACKUPS="7"

# Diretórios para backup
BACKUP_DIRS="data,models,configs"

# =============================================================================
# CONFIGURAÇÕES DE PERFORMANCE
# =============================================================================

# Limite de memória do sistema (%)
MEMORY_LIMIT_PERCENT="80"

# Limite de CPU do sistema (%)
CPU_LIMIT_PERCENT="80"

# Timeout para operações (segundos)
OPERATION_TIMEOUT="300"

# Número máximo de conexões simultâneas
MAX_CONNECTIONS="100"

# =============================================================================
# CONFIGURAÇÕES DE DESENVOLVIMENTO
# =============================================================================

# Habilitar modo debug
DEBUG_MODE="false"

# Habilitar profiling
ENABLE_PROFILING="false"

# Diretório para arquivos de debug
DEBUG_DIR="debug"

# =============================================================================
# CONFIGURAÇÕES AVANÇADAS
# =============================================================================

# Configurações específicas do sistema operacional
OS_SPECIFIC_CONFIG=""

# Variáveis de ambiente adicionais
EXTRA_ENV_VARS=""

# Configurações customizadas do usuário
CUSTOM_CONFIG=""
